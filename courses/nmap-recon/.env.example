# Nmap Training Lab Configuration
COMPOSE_PROJECT_NAME=nmap-lab

# CTFd Configuration
CTFD_SECRET_KEY=nmap-training-lab-secret-key-change-me
MYSQL_ROOT_PASSWORD=ctfd_root_pass_2024
MYSQL_DATABASE=ctfd
MYSQL_USER=ctfd
MYSQL_PASSWORD=ctfd_db_pass_2024

# Solution guide password (given to students after class)
SOLUTION_PASSWORD=instructor2024

# CTF timer (starts when first category unlocks)
CTF_DURATION_MINUTES=120
# Additional time per extension (instructor can add via API)
CTF_EXTEND_MINUTES=60

# PT challenge flags (instructor sets before class, gives verbally to students who pass)
PT_PLANK_FLAG=FLAG{1:30}
PT_SITUP_FLAG=FLAG{42}

# Host IP for students to reach CTFd (set to your machine's LAN IP)
# Leave empty to auto-detect, or set manually: CTFD_HOST=192.168.1.100
CTFD_HOST=

# Student terminal count (for reference; services are defined individually)
STUDENT_COUNT=10

# Team passwords (shared between Shell-in-a-Box and CTFd)
TEAM1_PASS=scan4flags1
TEAM2_PASS=scan4flags2
TEAM3_PASS=scan4flags3
TEAM4_PASS=scan4flags4
TEAM5_PASS=scan4flags5
TEAM6_PASS=scan4flags6
TEAM7_PASS=scan4flags7
TEAM8_PASS=scan4flags8
TEAM9_PASS=scan4flags9
TEAM10_PASS=scan4flags10
